generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── 카테고리 (트리 구조) ───

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  order    Int        @default(0)

  products Product[]
  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ─── 제품 ───

model Product {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  description String?  @db.Text
  usage       String?
  scope       String?  @db.Text
  mixRatio    String?
  method      String?  @db.Text
  curing      String?
  packaging   String?

  properties  ProductProperty[]
  documents   Document[]
  standards   ProductStandard[]
  articles    ArticleProduct[]
  embeddings  Embedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

// ─── 제품 물성 데이터 ───

model ProductProperty {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  unit       String
  standard   String?
  value      String
  testMethod String?
  testDate   DateTime?
  passed     Boolean @default(true)

  @@map("product_properties")
}

// ─── KS 규격/표준 ───

model Standard {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String? @db.Text
  category    String?

  products ProductStandard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("standards")
}

model ProductStandard {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  standardId String
  standard   Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@id([productId, standardId])
  @@map("product_standards")
}

// ─── 위키 문서 ───

model Article {
  id         String  @id @default(cuid())
  title      String
  slug       String  @unique
  content    String  @db.Text
  excerpt    String?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tags       String[]
  published  Boolean   @default(false)
  version    Int       @default(1)
  author     String?

  products   ArticleProduct[]
  embeddings Embedding[]
  versions   ArticleVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
}

model ArticleVersion {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  version   Int
  title     String
  content   String  @db.Text
  author    String?

  createdAt DateTime @default(now())

  @@map("article_versions")
}

model ArticleProduct {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([articleId, productId])
  @@map("article_products")
}

// ─── 업로드 PDF 문서 ───

model Document {
  id             String  @id @default(cuid())
  fileName       String
  filePath       String
  storageUrl     String?
  fileSize       Int
  mimeType       String  @default("application/pdf")
  documentType   String  @default("OTHER")
  autoClassified Boolean @default(false)
  confirmed      Boolean @default(false)
  extractedText  String? @db.Text
  pageCount      Int?
  productId      String?
  product        Product? @relation(fields: [productId], references: [id])

  embeddings Embedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

// ─── 벡터 임베딩 (RAG) ───

model Embedding {
  id         String                          @id @default(cuid())
  content    String                          @db.Text
  vector     Unsupported("vector(768)")?
  metadata   Json?

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  articleId  String?
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("embeddings")
}

// ─── AI 대화 이력 ───

model ChatSession {
  id       String        @id @default(cuid())
  title    String?
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String      @db.Text
  sources   Json?
  feedback  Int?

  createdAt DateTime @default(now())

  @@map("chat_messages")
}
